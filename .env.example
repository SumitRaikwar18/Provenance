MEMWAL_KEY=your_delegate_private_key_hex
MEMWAL_ACCOUNT_ID=0x_your_memwal_account_id
MEMWAL_SERVER_URL=https://relayer.memory.walrus.xyz

WALRUS_PUBLISHER=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
NEXT_PUBLIC_APP_NAME=Provenance
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Seal threshold encryption configuration.
# Deploy move/provenance_seal first, then set the first-version package ID and key server objects.
NEXT_PUBLIC_SEAL_ENABLED=false
NEXT_PUBLIC_SEAL_PACKAGE_ID=0x_your_first_version_provenance_seal_package
NEXT_PUBLIC_SEAL_MODULE=provenance_private
NEXT_PUBLIC_SEAL_THRESHOLD=2
# JSON format is recommended. Example:
# NEXT_PUBLIC_SEAL_KEY_SERVERS=[{"objectId":"0x_key_server_1","weight":1,"aggregatorUrl":"https://seal-testnet-aggregator.example"},{"objectId":"0x_key_server_2","weight":1,"aggregatorUrl":"https://seal-testnet-aggregator.example"}]
NEXT_PUBLIC_SEAL_KEY_SERVERS=

# Optional - enables the AI Writing Agent ("Agent Insights" in the dashboard).
# Without this key the agent panel shows a stub message instead of LLM analysis.
OPENAI_API_KEY=your_openai_api_key
